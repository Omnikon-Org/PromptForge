{
  "name": "@promptforgee/core",
  "version": "1.0.1",
  "description": "Production-grade prompt engineering toolkit. Type-safe, composable, and extensible.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "vitest": "^1.6.0",
    "typescript": "^5.4.5"
  },
  "author": "Omnikon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Omnikon-Org/PromptForge.git",
    "directory": "packages/core"
  },
  "homepage": "https://prompt-forge-docs.vercel.app/",
  "bugs": {
    "url": "https://github.com/Omnikon-Org/PromptForge/issues"
  },
  "keywords": [
    "prompt",
    "prompt-engineering",
    "llm",
    "ai",
    "typescript",
    "openai",
    "anthropic",
    "gemini",
    "ollama",
    "zod",
    "compiler",
    "developer-tools"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "funding": "https://github.com/sponsors/Omnikon-Org",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  }
}
